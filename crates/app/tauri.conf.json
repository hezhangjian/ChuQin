{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChuQin",
  "version": "0.1.0",
  "identifier": "com.chuqin.app",
  "build": {
    "beforeDevCommand": "pnpm --dir portal dev --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "pnpm --dir portal build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../portal/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ChuQin",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
